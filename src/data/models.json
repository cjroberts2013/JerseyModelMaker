{
  "_note": "Fonts moved to /public/fonts.json. Each text zone's defaultFont now references a font by `name` from that catalog.",
  "templates": [
    {
      "id": "nfl-jersey",
      "parts": [
        {
          "id": "frame",
          "name": "Frame",
          "file": "/models/nfl-jersey-base/frame.stl",
          "defaultColor": "#0a0a0a",
          "exportGroup": "withoutText",
          "exportFilename": "black frame.stl"
        },
        {
          "id": "matte",
          "name": "Background",
          "file": "/models/nfl-jersey-base/matte.stl",
          "defaultColor": "#e8e8e8",
          "exportGroup": "withText",
          "exportFilename": "NFLbackground_with_text_{teamName}_{fullName}.stl",
          "_comment": "V2 matte uses origin-at-corner coords. Y offset is -matte.dy/2 + innerMatte.centerY (=2.50) so matte and inner matte share a Y-center and the visible border is symmetric. Z places the matte back flush with the inner-matte back (-4.6); front face lands at z=-2.6 per the surface quads below.",
          "position": [-57.86, -86.29, -4.6]
        },
        {
          "id": "jersey",
          "name": "Jersey",
          "file": "/models/nfl-jersey-base/jersey.stl",
          "defaultColor": "#1e40af",
          "exportGroup": "withText",
          "exportFilename": "JERSSEY_with_text_{playerName}_{playerNumber}.stl"
        },
        {
          "id": "background",
          "name": "Inner Matte",
          "file": "/models/nfl-jersey-base/background.stl",
          "defaultColor": "#f5f5f5",
          "exportGroup": "withoutText",
          "exportFilename": "white frame.stl"
        },
        {
          "id": "stand",
          "name": "Stand",
          "file": "/models/nfl-jersey-base/stand.stl",
          "defaultColor": "#cccccc",
          "exportGroup": "stl",
          "exportFilename": "x 4.stl"
        }
      ],
      "textZones": [
        {
          "id": "teamName",
          "label": "TEAM NAME",
          "defaultText": "TEAM\nNAME",
          "defaultFont": "Arial Black",
          "defaultSize": 13,
          "defaultDepth": 2.5,
          "defaultSpacing": -0.4,
          "defaultLineSpacing": -3.5,
          "defaultAlign": "center",
          "defaultColor": "#1a1a1a",
          "defaultEmbed": 0.4,
          "onPart": "matte",
          "surface": {
            "point1": [-50, 85.5, -2.6],
            "point2": [50, 85.5, -2.6],
            "point3": [50, 54.5, -2.6],
            "point4": [-50, 54.5, -2.6]
          }
        },
        {
          "id": "playerName",
          "label": "PLAYER NAME",
          "defaultText": "NAME",
          "defaultFont": "College",
          "defaultSize": 12,
          "defaultDepth": 2.5,
          "defaultSpacing": 0,
          "defaultAlign": "center",
          "defaultColor": "#f5f5f5",
          "defaultEmbed": 0.8,
          "onPart": "jersey",
          "surface": {
            "point1": [-28, 38, 0.6],
            "point2": [28, 38, 0.6],
            "point3": [28, 28, 0.6],
            "point4": [-28, 28, 0.6]
          }
        },
        {
          "id": "playerNumber",
          "label": "PLAYER NUMBER",
          "defaultText": "00",
          "defaultFont": "College Bold",
          "defaultSize": 48.5,
          "defaultDepth": 2.5,
          "defaultSpacing": -1.1,
          "defaultAlign": "center",
          "defaultColor": "#a0a0a0",
          "defaultEmbed": 0.8,
          "onPart": "jersey",
          "surface": {
            "point1": [-36, 25.5, 0.6],
            "point2": [36, 25.5, 0.6],
            "point3": [36, -14.5, 0.6],
            "point4": [-36, -14.5, 0.6]
          }
        },
        {
          "id": "fullName",
          "label": "YOUR FULL NAME",
          "defaultText": "Your\nName",
          "defaultFont": "Arial Black",
          "defaultSize": 9,
          "defaultDepth": 2.5,
          "defaultSpacing": 0,
          "defaultAlign": "left",
          "defaultColor": "#111111",
          "defaultEmbed": 0.4,
          "onPart": "matte",
          "surface": {
            "point1": [-55.5, -61.5, -2.6],
            "point2": [-10.5, -61.5, -2.6],
            "point3": [-10.5, -83.5, -2.6],
            "point4": [-55.5, -83.5, -2.6]
          }
        }
      ]
    }
  ],
