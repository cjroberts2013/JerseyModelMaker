            { "id": "jersey", "name": "Jersey", "file": "/models/nfl-jersey-base/jersey.stl", "defaultColor": "#1e40af", "exportGroup": "withText", "exportFilename": "JERSSEY_with_text_{playerName}_{playerNumber}.stl" }
          ]
